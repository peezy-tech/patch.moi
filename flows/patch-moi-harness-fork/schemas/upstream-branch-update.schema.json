{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["repo", "ref", "sha"],
  "properties": {
    "repo": {
      "type": "string",
      "enum": ["peezy-tech/patch-moi-harness"]
    },
    "ref": {
      "type": "string",
      "enum": ["refs/heads/main"]
    },
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{7,40}$"
    }
  },
  "additionalProperties": true
}
